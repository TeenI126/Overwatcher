<Window x:Class="OwTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OwTracker.App"
        xmlns:vm="clr-namespace:OwTracker.App.ViewModels"
        xmlns:conv="clr-namespace:OwTracker.App.Converters"
        xmlns:ctrl="clr-namespace:OwTracker.App.Controls"
        xmlns:views="clr-namespace:OwTracker.App.Views"
        mc:Ignorable="d"
        Title="Overwatcher" Height="780" Width="1180"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <local:BoolToStatusBrushConverter x:Key="BoolToBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Screen → view mapping: ContentControl renders the active VM via these templates. -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MatchHistoryViewModel}"><views:MatchHistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeroMapViewModel}"><views:HeroMapView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionViewModel}"><views:SessionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RankHistoryViewModel}"><views:RankHistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeroReviewViewModel}"><views:HeroReviewView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>

        <!-- Rail item content (icon dot + label) -->
        <DataTemplate x:Key="NavItemTemplate">
            <TextBlock Text="{Binding Label}" FontSize="12" />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT RAIL ============ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,16">
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,0,16">
                    <Border Width="26" Height="26" Background="{StaticResource AccentBrush}"
                            ctrl:NotchClip.TopRight="9">
                        <TextBlock Text="O" FontFamily="{StaticResource HeadFont}" FontWeight="Bold"
                                   Foreground="#FF1A1205" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" Margin="9,0,0,0"
                               FontFamily="{StaticResource HeadFont}" FontWeight="Bold" FontSize="14">
                        <Run Text="OVER" Foreground="{StaticResource TextBrush}" /><Run Text="WATCHER" Foreground="{StaticResource AccentBrush}" />
                    </TextBlock>
                </StackPanel>

                <!-- Status chips (bottom) -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Style="{StaticResource Inset}" Padding="10,9" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                     Fill="{Binding Watcher.IsOwRunning, Converter={StaticResource BoolToBrush}}" />
                            <TextBlock Text="Overwatch detected" Margin="8,0,0,0" FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Inset}" Padding="10,9" Margin="0,6,0,0">
                        <DockPanel>
                            <TextBlock Text="Session" FontSize="11.5" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}" FontSize="11.5"
                                       Text="{Binding Watcher.CurrentActiveDuration, StringFormat={}{0:hh\\:mm\\:ss}}" />
                        </DockPanel>
                    </Border>
                    <Border Style="{StaticResource Inset}" Padding="10,9" Margin="0,6,0,0">
                        <DockPanel>
                            <TextBlock Text="Database" FontSize="11.5" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}" FontSize="11.5"
                                       Text="{Binding Dashboard.MatchCount, StringFormat={}{0} games}" />
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Nav (primary + system groups) -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TRACKER" Style="{StaticResource MicroLabel}" Margin="8,8,0,4" />
                    <ListBox ItemsSource="{Binding TrackerNav}" SelectedItem="{Binding SelectedNav, Mode=TwoWay}"
                             Style="{StaticResource RailList}" ItemContainerStyle="{StaticResource RailItem}"
                             ItemTemplate="{StaticResource NavItemTemplate}" />
                    <TextBlock Text="SYSTEM" Style="{StaticResource MicroLabel}" Margin="8,14,0,4" />
                    <ListBox ItemsSource="{Binding SystemNav}" SelectedItem="{Binding SelectedNav, Mode=TwoWay}"
                             Style="{StaticResource RailList}" ItemContainerStyle="{StaticResource RailItem}"
                             ItemTemplate="{StaticResource NavItemTemplate}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
