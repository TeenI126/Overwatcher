<Window x:Class="OwTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OwTracker.App"
        xmlns:views="clr-namespace:OwTracker.App.Views"
        mc:Ignorable="d"
        Title="OW Tracker" Height="720" Width="1100">
    <Window.Resources>
        <local:BoolToTextConverter x:Key="BoolToText" />
        <local:BoolToStatusBrushConverter x:Key="BoolToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <DockPanel>
        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                             Fill="{Binding Watcher.IsOwInForeground, Converter={StaticResource BoolToBrush}}" />
                    <TextBlock Margin="6,0,0,0"
                               Text="{Binding Watcher.IsOwInForeground, Converter={StaticResource BoolToText},
                                      ConverterParameter='Overwatch detected|Overwatch not detected'}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding Watcher.CurrentActiveDuration, StringFormat='Session: {0:hh\\:mm\\:ss}'}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding HeroReview.UnreviewedCount, StringFormat='Review queue: {0}'}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Tabs -->
        <TabControl Margin="8">
            <TabItem Header="Dashboard">
                <views:DashboardView DataContext="{Binding Dashboard}" />
            </TabItem>
            <TabItem Header="Match History">
                <views:MatchHistoryView DataContext="{Binding MatchHistory}" />
            </TabItem>
            <TabItem Header="Sessions">
                <views:SessionView DataContext="{Binding Sessions}" />
            </TabItem>
            <TabItem Header="Hero Review">
                <views:HeroReviewView DataContext="{Binding HeroReview}" />
            </TabItem>
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
