<UserControl x:Class="OwTracker.App.Views.RankHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:OwTracker.App.Converters"
             xmlns:ctrl="clr-namespace:OwTracker.App.Controls"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="980"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="NotVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Border Grid.Row="0" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="22,18,22,14">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="RANK HISTORY" Style="{StaticResource H1}" />
                    <TextBlock Text="competitive ladder over time" Style="{StaticResource Crumb}"
                               VerticalAlignment="Bottom" Margin="12,0,0,3" />
                </StackPanel>
                <Border DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource KpiTile}">
                    <StackPanel>
                        <TextBlock Text="{Binding SnapshotCount}" Style="{StaticResource KpiValue}" />
                        <TextBlock Text="Snapshots" Style="{StaticResource KpiKey}" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ===== Body ===== -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <Border Visibility="{Binding HasData, Converter={StaticResource NotVis}}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                <StackPanel>
                    <TextBlock Text="No rank captured yet" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold"
                               FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"
                               Foreground="{StaticResource MutedBrush}" FontSize="12.5"
                               Text="Run a scrape while Overwatch is open — your competitive rank is captured at the start of every scrape, and the trend builds up here." />
                </StackPanel>
            </Border>

            <!-- Content -->
            <DockPanel Visibility="{Binding HasData, Converter={StaticResource BoolVis}}" Margin="22,16,22,22">

                <!-- Ticker tape -->
                <Border DockPanel.Dock="Top" Style="{StaticResource Panel}" Padding="6,4">
                    <ItemsControl ItemsSource="{Binding Tape}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6" Padding="12,9" Background="{StaticResource Panel2Brush}"
                                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                                        ctrl:NotchClip.TopRight="9">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding Card.RoleColor}" />
                                            <TextBlock Text="{Binding Card.Role}" Margin="7,0,0,0" VerticalAlignment="Center"
                                                       Style="{StaticResource MicroLabel}" />
                                            <TextBlock Text="{Binding DeltaText}" Margin="8,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource NumFont}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding DeltaColor}"
                                                       Visibility="{Binding HasDelta, Converter={StaticResource BoolVis}}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Card.RankText}" Margin="0,5,0,0"
                                                   FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="17"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding Card.DetailText}" Margin="0,1,0,0"
                                                   FontFamily="{StaticResource NumFont}" FontSize="11.5"
                                                   Foreground="{Binding Card.DetailColor}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Chart -->
                <Border Style="{StaticResource Panel}" Margin="0,14,0,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="LADDER TREND" Style="{StaticResource PanelTitle}" />
                            <TextBlock DockPanel.Dock="Right" Text="{Binding RangeText}" Style="{StaticResource PanelTag}" />
                        </DockPanel>

                        <!-- One-capture hint -->
                        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0"
                                Visibility="{Binding HasTrend, Converter={StaticResource NotVis}}">
                            <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11.5" TextWrapping="Wrap"
                                       Text="Only one capture so far — each role shows as a single point on the ladder. Scrape again to start drawing the trend line." />
                        </Border>

                        <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" MinHeight="340">
                            <ctrl:RankTicker Model="{Binding Chart}" />
                        </Border>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
