<UserControl x:Class="OwTracker.App.Views.HeroMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:OwTracker.App.Converters"
             xmlns:ctrl="clr-namespace:OwTracker.App.Controls"
             xmlns:nav="clr-namespace:OwTracker.App.Navigation"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="980"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:PercentConverter x:Key="Percent" />
        <conv:ClockConverter x:Key="Clock" />
        <conv:RoleToBrushConverter x:Key="RoleBrush" />
        <conv:ModeToBrushConverter x:Key="ModeBrush" />
        <conv:WinRateToBackgroundConverter x:Key="WrBg" />
        <conv:WinRateToForegroundConverter x:Key="WrFg" />
        <conv:DoubleToStarConverter x:Key="Star" />
        <conv:EqualsToVisibilityConverter x:Key="EqVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis" />

        <!-- ranked row: heroes on a map -->
        <DataTemplate x:Key="RankHeroTemplate">
            <Border Background="{StaticResource Panel2Brush}" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="1" Padding="12,9" Margin="0,0,0,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="58" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Rank}" Style="{StaticResource MonoMuted}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:HeroChip HeroName="{Binding Name}" Role="{Binding Role}" ChipSize="24" />
                        <TextBlock Text="{Binding Name}" Margin="9,0,0,0" VerticalAlignment="Center" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="13" />
                    </StackPanel>
                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="38" /></Grid.ColumnDefinitions>
                        <Grid Height="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource Star}}" />
                                <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource Star}, ConverterParameter=rest}" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource AccentBrush}" />
                            <Border Grid.Column="1" Background="{StaticResource LineBrush}" />
                        </Grid>
                        <TextBlock Grid.Column="1" TextAlignment="Right" Style="{StaticResource Mono}" FontWeight="SemiBold"
                                   Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" />
                    </Grid>
                    <TextBlock Grid.Column="3" Style="{StaticResource Mono}" TextAlignment="Right">
                        <Run Text="{Binding Wins, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Losses, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Grid.Column="4" Style="{StaticResource Mono}" TextAlignment="Right" Text="{Binding Kda, StringFormat=F1}" />
                    <TextBlock Grid.Column="5" Style="{StaticResource MonoMuted}" TextAlignment="Right">
                        <Run Text="{Binding AvgElim, Mode=OneWay, StringFormat=F0}" /><Run Text="/" /><Run Text="{Binding AvgDeath, Mode=OneWay, StringFormat=F0}" />
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ranked row: maps for a hero -->
        <DataTemplate x:Key="RankMapTemplate">
            <Border Background="{StaticResource Panel2Brush}" BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="1" Padding="12,9" Margin="0,0,0,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="58" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Rank}" Style="{StaticResource MonoMuted}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Rectangle Width="9" Height="9" VerticalAlignment="Center" Fill="{Binding Mode, Converter={StaticResource ModeBrush}}" />
                        <TextBlock Text="{Binding Name}" Margin="9,0,0,0" VerticalAlignment="Center" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="13" />
                    </StackPanel>
                    <Grid Grid.Column="2" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="38" /></Grid.ColumnDefinitions>
                        <Grid Height="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource Star}}" />
                                <ColumnDefinition Width="{Binding WinRate, Converter={StaticResource Star}, ConverterParameter=rest}" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource AccentBrush}" />
                            <Border Grid.Column="1" Background="{StaticResource LineBrush}" />
                        </Grid>
                        <TextBlock Grid.Column="1" TextAlignment="Right" Style="{StaticResource Mono}" FontWeight="SemiBold"
                                   Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" />
                    </Grid>
                    <TextBlock Grid.Column="3" Style="{StaticResource Mono}" TextAlignment="Right">
                        <Run Text="{Binding Wins, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Losses, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Grid.Column="4" Style="{StaticResource Mono}" TextAlignment="Right" Text="{Binding Kda, StringFormat=F1}" />
                    <TextBlock Grid.Column="5" Style="{StaticResource MonoMuted}" TextAlignment="Right">
                        <Run Text="{Binding AvgElim, Mode=OneWay, StringFormat=F0}" /><Run Text="/" /><Run Text="{Binding AvgDeath, Mode=OneWay, StringFormat=F0}" />
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Border Grid.Row="0" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="22,18,22,14">
            <StackPanel>
                <DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="HERO × MAP" Style="{StaticResource H1}" />
                        <TextBlock Text="{Binding Crumb}" Style="{StaticResource Crumb}" VerticalAlignment="Bottom" Margin="12,0,0,3" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right" Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SegButton}" Content="HEATMAP" Command="{Binding ShowHeatmapCommand}" />
                            <Button Style="{StaticResource SegButton}" Content="BY MAP" Command="{Binding ShowByMapCommand}" />
                            <Button Style="{StaticResource SegButton}" Content="BY HERO" Command="{Binding ShowByHeroCommand}" />
                        </StackPanel>
                    </Border>
                </DockPanel>

                <!-- Mode filter -->
                <WrapPanel Margin="0,12,0,0" Visibility="{Binding ShowModeFilter, Converter={StaticResource BoolVis}}">
                    <ToggleButton Style="{StaticResource PillToggle}" Content="All modes" Margin="0,0,6,0"
                                  IsChecked="{Binding AllModesActive, Mode=OneWay}" Command="{Binding ClearModesCommand}" />
                    <ItemsControl ItemsSource="{Binding ModeChips}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Style="{StaticResource PillToggle}" Margin="0,0,6,0" IsChecked="{Binding IsActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="7" Height="7" VerticalAlignment="Center" Fill="{Binding Name, Converter={StaticResource ModeBrush}}" />
                                        <TextBlock Text="{Binding Name}" Margin="6,0,0,0" />
                                    </StackPanel>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ===== Body ===== -->
        <Grid Grid.Row="1" Margin="22,16,22,16">
            <!-- HEATMAP -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding View, Converter={StaticResource EqVis}, ConverterParameter=Heatmap}">
                <StackPanel>
                    <!-- legend -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Lower" Foreground="{StaticResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center" />
                        <Border Width="132" Height="9" Margin="10,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#2e4258" Offset="0" />
                                    <GradientStop Color="#46464d" Offset="0.4" />
                                    <GradientStop Color="#c87327" Offset="0.76" />
                                    <GradientStop Color="#ff9d44" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Higher win rate" Foreground="{StaticResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center" />
                        <TextBlock Text="· click a map header to drill in" Foreground="{StaticResource MutedBrush}" FontSize="11.5" VerticalAlignment="Center" Margin="14,0,0,0" />
                    </StackPanel>

                    <!-- column headers -->
                    <StackPanel Orientation="Horizontal">
                        <Border Width="150" />
                        <ItemsControl ItemsSource="{Binding HeatMaps}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PlainButton}" Width="60" Height="94" VerticalContentAlignment="Bottom"
                                            Command="{Binding DataContext.PickMapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Map}">
                                        <StackPanel VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding Map}" Foreground="{StaticResource MutedBrush}" FontSize="10.5" Margin="0,0,0,4">
                                                <TextBlock.LayoutTransform><RotateTransform Angle="-50" /></TextBlock.LayoutTransform>
                                            </TextBlock>
                                            <Border Height="3" Margin="3,0" Background="{Binding Mode, Converter={StaticResource ModeBrush}}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Overall" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Width="64" VerticalAlignment="Bottom" TextAlignment="Center" />
                    </StackPanel>

                    <!-- rows -->
                    <ItemsControl ItemsSource="{Binding HeatRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <!-- row head -->
                                    <StackPanel Width="150" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ctrl:HeroChip HeroName="{Binding Hero.Name}" Role="{Binding Hero.Role}" ChipSize="26" />
                                        <TextBlock Text="{Binding Hero.Name}" Margin="9,0,0,0" VerticalAlignment="Center" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="12" />
                                        <TextBlock Text="{Binding Hero.Games, StringFormat={}{0}g}" Margin="6,0,0,0" VerticalAlignment="Center" Style="{StaticResource MonoMuted}" FontSize="11" />
                                    </StackPanel>
                                    <!-- cells -->
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource PlainButton}" Width="60" Height="44" Padding="1"
                                                        Command="{Binding DataContext.PickMapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Map}">
                                                    <Grid>
                                                        <!-- data cell -->
                                                        <Border Background="{Binding WinRate, Converter={StaticResource WrBg}}"
                                                                Visibility="{Binding HasData, Converter={StaticResource BoolVis}}">
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding WinRate, Converter={StaticResource Percent}}" HorizontalAlignment="Center"
                                                                           FontFamily="{StaticResource NumFont}" FontSize="13.5" FontWeight="SemiBold"
                                                                           Foreground="{Binding WinRate, Converter={StaticResource WrFg}}" />
                                                                <TextBlock Text="{Binding Games, StringFormat={}{0}g}" HorizontalAlignment="Center" FontFamily="{StaticResource NumFont}" FontSize="9"
                                                                           Opacity="0.72" Foreground="{Binding WinRate, Converter={StaticResource WrFg}}" />
                                                            </StackPanel>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Low}" Value="True"><Setter Property="Opacity" Value="0.5" /></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <!-- empty cell -->
                                                        <Border BorderBrush="{StaticResource LineSoftBrush}" BorderThickness="1"
                                                                Visibility="{Binding HasData, Converter={StaticResource InvBoolVis}}">
                                                            <TextBlock Text="·" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Opacity="0.35" />
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- overall -->
                                    <Border Width="64" Height="44" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="2,0,0,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Hero.WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" HorizontalAlignment="Center"
                                                       FontFamily="{StaticResource NumFont}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource NumFont}" FontSize="9" Foreground="{StaticResource MutedBrush}">
                                                <Run Text="{Binding Hero.Wins, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Hero.Losses, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- BY MAP -->
            <Grid Visibility="{Binding View, Converter={StaticResource EqVis}, ConverterParameter=ByMap}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="264" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ListBox Grid.Column="0" Style="{StaticResource PlainList}" ItemsSource="{Binding MapList}"
                         SelectedItem="{Binding SelectedMap}" ItemContainerStyle="{StaticResource BmItem}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Rectangle Width="7" Height="7" VerticalAlignment="Center" Fill="{Binding Mode, Converter={StaticResource ModeBrush}}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" Style="{StaticResource Mono}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Games, StringFormat={}{0}g}" Style="{StaticResource MonoMuted}" FontSize="10" Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding Map}" Margin="10,0" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="20,18">
                    <DockPanel DataContext="{Binding SelectedMap}">
                        <!-- header -->
                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Rectangle Width="9" Height="9" VerticalAlignment="Center" Fill="{Binding Mode, Converter={StaticResource ModeBrush}}" />
                                    <TextBlock Text="{Binding Map}" Margin="12,0,0,0" FontFamily="{StaticResource HeadFont}" FontWeight="Bold" FontSize="22" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValueAccent}" TextAlignment="Right" Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" />
                                        <TextBlock Text="Win rate" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right" Text="{Binding Games}" />
                                        <TextBlock Text="Games" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right">
                                            <Run Text="{Binding Wins, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Losses, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="Record" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right" Text="{Binding AvgLength, Converter={StaticResource Clock}}" />
                                        <TextBlock Text="Avg length" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.MapHeroRows}"
                                          ItemTemplate="{StaticResource RankHeroTemplate}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- BY HERO -->
            <Grid Visibility="{Binding View, Converter={StaticResource EqVis}, ConverterParameter=ByHero}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="264" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ListBox Grid.Column="0" Style="{StaticResource PlainList}" ItemsSource="{Binding HeroList}"
                         SelectedItem="{Binding SelectedHero}" ItemContainerStyle="{StaticResource BmItem}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <ctrl:HeroChip HeroName="{Binding Name}" Role="{Binding Role}" ChipSize="22" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" Style="{StaticResource Mono}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Games, StringFormat={}{0}g}" Style="{StaticResource MonoMuted}" FontSize="10" Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding Name}" Margin="10,0" FontFamily="{StaticResource HeadFont}" FontWeight="SemiBold" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="20,18">
                    <DockPanel DataContext="{Binding SelectedHero}">
                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,14">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ctrl:HeroChip HeroName="{Binding Name}" Role="{Binding Role}" ChipSize="40" />
                                    <TextBlock Text="{Binding Name}" Margin="12,0,0,0" FontFamily="{StaticResource HeadFont}" FontWeight="Bold" FontSize="22" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValueAccent}" TextAlignment="Right" Text="{Binding WinRate, Converter={StaticResource Percent}, ConverterParameter=sign}" />
                                        <TextBlock Text="Win rate" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right" Text="{Binding Games}" />
                                        <TextBlock Text="Games" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,22,0">
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right">
                                            <Run Text="{Binding Wins, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Losses, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="Record" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource KpiValue}" TextAlignment="Right" Text="{Binding Time, Converter={StaticResource Clock}}" />
                                        <TextBlock Text="Playtime" Style="{StaticResource MicroLabel}" TextAlignment="Right" />
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.HeroMapRows}"
                                          ItemTemplate="{StaticResource RankMapTemplate}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
